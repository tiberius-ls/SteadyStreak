# Nimiq address that receives combined daily save + stake transactions.
# Replace with your pool operator escrow address before mainnet use.
NEXT_PUBLIC_ESCROW_ADDRESS=NQ07 0000 0000 0000 0000 0000 0000 0000 0000

# Optional Postgres connection string (Neon, Vercel Postgres, Supabase, etc.).
# When set, leaderboard + stake pools are durable across deploys.
# When unset, the server uses an in-memory store (fine for local demo only).
# DATABASE_URL=postgresql://user:pass@host/db?sslmode=require
