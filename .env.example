# Public (baked into client)
NEXT_PUBLIC_ESCROW_ADDRESS=NQ07 0000 0000 0000 0000 0000 0000 0000 0000
# Set true only for staging/demo deploys. Production defaults to false.
# NEXT_PUBLIC_ALLOW_DEMO=false

# Server only
DATABASE_URL=postgresql://user:pass@host/db?sslmode=require
# Protects /operator and claim mark-paid endpoints
OPERATOR_SECRET=change-me-to-a-long-random-string
